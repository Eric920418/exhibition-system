# Database (Vercel Postgres / Neon)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth (NEXTAUTH_SECRET 至少需要 32 個字元)
# 生成方式: openssl rand -base64 32
# NEXTAUTH_URL 在 Vercel 上會自動設定，本地開發需要手動設定
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-at-least-32-characters-long-change-this"

# Upstash Redis (Vercel KV)
KV_REST_API_URL="https://your-redis.upstash.io"
KV_REST_API_TOKEN="your-upstash-token"

# Vercel Blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# Email (開發環境可使用本地 SMTP 或第三方服務)
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@exhibition.local"

# Public URLs
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# 跳過環境變數驗證（僅限建構時使用）
# SKIP_ENV_VALIDATION=true
