# Database (需要本地安裝 PostgreSQL 16)
DATABASE_URL="postgresql://your_user:your_password@localhost:5432/exhibition_db?schema=public"

# NextAuth (NEXTAUTH_SECRET 至少需要 32 個字元)
# 生成方式: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-at-least-32-characters-long-change-this"

# Redis (需要本地安裝 Redis 7)
REDIS_URL="redis://localhost:6379"

# MinIO (S3 Compatible) - 如果使用檔案儲存功能，需要本地安裝 MinIO
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="your-access-key"
MINIO_SECRET_KEY="your-secret-key"
MINIO_BUCKET_NAME="exhibition-bucket"

# Email (開發環境可使用本地 SMTP 或第三方服務)
SMTP_HOST="localhost"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@exhibition.local"

# Public URLs
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_WS_URL="http://localhost:3000"